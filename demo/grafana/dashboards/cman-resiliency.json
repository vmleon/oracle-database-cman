                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "auto",
        "rowHeight": 0.9,
        "alignValue": "left"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"workload\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"cman_workload\" and r._field == \"latency_ms\" and r.client == \"dumb\")\n  |> map(fn: (r) => ({ _time: r._time, _value: if r.status == \"error\" then \"error\" else r.inst }))\n  |> group()\n  |> sort(columns: [\"_time\"])"
        }
      ]
    },
    {
