cman_proxy =
  (configuration =
    (address = (protocol = tcp)(host = {{ cman_host }})(port = 1521))
    (parameter_list =
      (tdm = true)
      (tdm_threading_mode = dedicated)
      (max_connections = 1024)
      (idle_timeout = 0)
      (inbound_connect_timeout = 60)
      (log_level = user))
    (rule_list =
      (rule = (src = {{ client_cidr }})(dst = *)(srv = *)(act = accept))))
